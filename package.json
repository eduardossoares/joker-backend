{
  "name": "prato-feito-backend",
  "description": "API do PratoFeito, responsável por autenticação, publicações, comentários, reputação, votos e curadoria comunitária de conteúdos gastronômicos.",
  "module": "src/server.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "ci": "bun install --frozen-lockfile && bun run tsc --noEmit && bun build --target=bun --outdir=dist src/server.ts",
    "start": "NODE_ENV=production bun dist/server.js",
    "dev": "NODE_ENV=development bun --watch src/server.ts",
    "test:dev": "NODE_ENV=test bun test --watch",
    "docker:up": "docker compose -f infra/compose.yaml up -d",
    "docker:down": "docker compose -f infra/compose.yaml down -v",
    "check": "bunx biome check ./src ./tests ./infra",
    "check:fix": "bunx biome check --write ./src ./tests ./infra",
    "migration:create": "node-pg-migrate -m infra/migrations create",
    "migration:run": "node-pg-migrate -m infra/migrations --env-path .env.development up"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@types/bun": "1.3.10",
    "@types/node": "25.3.5",
    "@types/pg": "8.20.0",
    "node-pg-migrate": "8.0.4"
  },
  "peerDependencies": {
    "typescript": "5"
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "fastify": "5.8.1",
    "pg": "8.20.0"
  }
}
